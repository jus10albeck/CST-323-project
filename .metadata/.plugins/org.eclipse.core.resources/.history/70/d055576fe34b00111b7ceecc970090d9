
<!DOCTYPE html>
<html xmlns:th="http://www.thymeleaf.org"
      xmlns:layout="http://www.ultraq.net.nz/thymeleaf/layout"
      layout:decorate="layouts/defaultTemplate">

<head>
    <meta charset="UTF-8">
    <title>Recurring Tasks</title>
	
	<link rel="stylesheet"
	      href="https://cdn.jsdelivr.net/npm/bootstrap@3.4.1/dist/css/bootstrap.min.css">
	<link rel="stylesheet"
	      href="https://cdn.jsdelivr.net/npm/bootstrap@3.4.1/dist/css/bootstrap-theme.min.css">
	<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
	<script src="https://cdn.jsdelivr.net/npm/bootstrap@3.4.1/dist/js/bootstrap.min.js"></script>


    <style>
        body {
            background-color: #808080;
        }

        .section {
            width: 82%;
            margin: 15px auto;
        }

        .section-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .section-title {
            color: gold;
            font-size: 22px;
        }

        .add-btn {
            color: gold;
            cursor: pointer;
            font-size: 18px;
        }

        .add-btn:hover {
            transform: scale(1.2);
        }

        .task-box {
            border: 1px solid black;
            padding: 10px;
            height: 22vh;
            overflow-y: auto;
            background-color: #858585;
            margin-top: 5px;
            box-shadow: 0px 0px 5px rgba(0, 0, 0, 0.35);
        }

        .task-item {
            display: flex;
            align-items: center;
            margin-bottom: 10px;
            width: 100%;
        }

        .checkbox {
            transform: scale(1.3);
            margin-right: 5px;
        }

        .task-name {
            color: #87cefa;
            display: flex;
            align-items: center;
            width: 100%;
            cursor: pointer;
            padding: 5px 10px;
            margin-left: 10px;
            font-size: 18px;
        }

        .task-detail {
            margin-left: auto;
            color: gold;
            white-space: nowrap;
        }

        .collapse {
            background-color: #9a9a9a;
            margin-top: 5px;
            padding: 10px 20px;
        }

        .collapse p {
            margin: 4px 0;
            font-size: 14px;
        }

        .completed {
            text-decoration: line-through;
            color: gold;
        }
		

		#addDailyModal .modal-dialog,
		#addWeeklyModal .modal-dialog,
		#addMonthlyModal .modal-dialog {
		    margin: 10px auto;
		}


    </style>
</head>

<body>

<section layout:fragment="content">

    <!-- Top Bar -->
    <div th:insert="layouts/common :: topBar"></div>

    <!-- Daily -->
    <div class="section">

        <div class="section-header">
            <span class="section-title">Daily</span>
			<span class="add-btn glyphicon glyphicon-plus" 
			onclick="$('#addDailyModal').modal('show')"
			style="color: gold; font-size: 16px"></span>
        </div>

        <div class="task-box" >
            <div th:each="task, iter : ${dailyTasks}">

                <div class="task-item" style="display:flex; align-items:center;">

					<form th:action="@{/recurringtasks/complete}" method="post" style="display:inline;">
					    <input type="hidden" name="recurringTaskId" th:value="${task.id}">
					    <input type="checkbox"
					        class="checkbox"
					        th:checked="${task.completed}"
					        onchange="this.form.submit()">
					</form>

                    <span class="task-name"
                        data-toggle="collapse"
                        th:data-target="'#daily-' + ${iter.index}"
                        style="margin-left:10px; cursor:pointer;">
                        <span th:text="${task.name}"></span>
                    </span>

                    <span class="task-detail"
                        style="margin-left:auto;"
                        th:text="${task.address}">
                    </span>

                </div>

                <div th:id="'daily-' + ${iter.index}"
                    class="collapse"
                    style="padding-left:30px; color:white;">

                    <p><strong>Time:</strong>
                        <span th:text="${task.address}"></span>
                    </p>

                    <p><strong>Notes:</strong>
                        <span th:text="${task.notes}"></span>
                    </p>

                </div>

            </div>
        </div>    

    </div>

    <!-- Add Daily Task Modal -->
    <div class="modal fade" id="addDailyModal">
        <div class="modal-dialog">
            <div class="modal-content">

                <form th:action="@{/recurringtasks/addDaily}" method="post">
                    <div class="modal-header">
                        <button type="button" class="close" data-dismiss="modal">&times;</button>
                        <h4>Add Daily Task</h4>
                    </div>

                    <div class="modal-body">

                        <input type="text" name="name" class="form-control" placeholder="Name"><br>

                        <input type="time" name="time" class="form-control"><br>

                        <input type="text" name="address" class="form-control" placeholder="Address"><br>

                        <textarea name="notes" class="form-control" placeholder="Notes"></textarea>

                    </div>

                    <div class="modal-footer">
                        <button type="submit" class="btn btn-primary">Add</button>
                        <button type="button" class="btn btn-default" data-dismiss="modal">Cancel</button>
                    </div>

                </form>

            </div>
        </div>
    </div>

    <!-- Weekly -->
    <div class="section">

        <div class="section-header">
            <span class="section-title">Weekly</span>
			<button type="button" class="add-btn" onclick="$('#addWeeklyModal').modal('show')">+</button>
        </div>

        <div class="task-box" >


            <div th:each="task, iter : ${weeklyTasks}">

                <div class="task-item" style="display:flex; align-items:center;">


					<form th:action="@{/recurringtasks/complete}" method="post" style="display:inline;">
					    <input type="hidden" name="recurringTaskId" th:value="${task.id}">
					    <input type="checkbox"
					        class="checkbox"
					        th:checked="${task.completed}"
					        onchange="this.form.submit()">
					</form>

                    <span class="task-name"
                        data-toggle="collapse"
                        th:data-target="'#weekly-' + ${iter.index}"
                        style="margin-left:10px; cursor:pointer;">
                        <span th:text="${task.name}"></span>
                    </span>

                    <span class="task-detail"
                        style="margin-left:auto;"
                        th:text="${task.address}">
                    </span>

                </div>

                <div th:id="'weekly-' + ${iter.index}"
                    class="collapse"
                    style="padding-left:30px; color:white;">

                    <p><strong>Time:</strong>
                        <span th:text="${task.address}"></span>
                    </p>

                    <p><strong>Notes:</strong>
                        <span th:text="${task.notes}"></span>
                    </p>

                </div>

            </div>
        </div>    

    </div>

    <!-- Add Weekly Task Modal -->
    <div class="modal fade" id="addWeeklyModal">
        <div class="modal-dialog">
            <div class="modal-content">

                <form th:action="@{/recurringtasks/addWeekly}" method="post">
                    <div class="modal-header">
                        <h4>Add Weekly Task</h4>
                    </div>

                    <div class="modal-body">

                        <input type="text" name="name" class="form-control" placeholder="Name"><br>

                        <!-- Days of week -->
                        <div>
                            <label><input type="checkbox" name="days" value="Mon"> M</label>
                            <label><input type="checkbox" name="days" value="Tue"> T</label>
                            <label><input type="checkbox" name="days" value="Wed"> W</label>
                            <label><input type="checkbox" name="days" value="Thu"> T</label>
                            <label><input type="checkbox" name="days" value="Fri"> F</label>
                            <label><input type="checkbox" name="days" value="Sat"> S</label>
                            <label><input type="checkbox" name="days" value="Sun"> S</label>
                        </div><br>

                        <input type="time" name="time" class="form-control"><br>

                        <input type="text" name="address" class="form-control" placeholder="Address"><br>

                        <textarea name="notes" class="form-control" placeholder="Notes"></textarea>

                    </div>

                    <div class="modal-footer">
                        <button type="submit" class="btn btn-primary">Add</button>
                        <button type="button" class="btn btn-default" data-dismiss="modal">Cancel</button>
                    </div>

                </form>

            </div>
        </div>
    </div>

    <!-- Monthly -->
    <div class="section">

        <div class="section-header">
            <span class="section-title">Monthly</span>
			<button type="button" class="add-btn" onclick="$('#addMonthlyModal').modal('show')">+</button>
        </div>

        <div class="task-box" >


            <div th:each="task, iter : ${monthlyTasks}">

                <div class="task-item" style="display:flex; align-items:center;">


					<form th:action="@{/recurringtasks/complete}" method="post" style="display:inline;">
					    <input type="hidden" name="recurringTaskId" th:value="${task.id}">
					    <input type="checkbox"
					        class="checkbox"
					        th:checked="${task.completed}"
					        onchange="this.form.submit()">
					</form>

                    <span class="task-name"
                        data-toggle="collapse"
                        th:data-target="'#monthly-' + ${iter.index}"
                        style="margin-left:10px; cursor:pointer;">
                        <span th:text="${task.name}"></span>
                    </span>

                    <span class="task-detail"
                        style="margin-left:auto;"
                        th:text="${task.address}">
                    </span>

                </div>

                <div th:id="'monthly-' + ${iter.index}"
                    class="collapse"
                    style="padding-left:30px; color:white;">

                    <p><strong>Date:</strong>
                        <span th:text="${task.address}"></span>
                    </p>

                    <p><strong>Notes:</strong>
                        <span th:text="${task.notes}"></span>
                    </p>

                </div>

            </div>
        </div>    

    </div>

    <!-- Add Monthly Task Modal -->
    <div class="modal fade" id="addMonthlyModal">
        <div class="modal-dialog">
            <div class="modal-content">

                <form th:action="@{/recurringtasks/addMonthly}" method="post">
                    <div class="modal-header">
                        <h4>Add Monthly Task</h4>
                    </div>

                    <div class="modal-body">

                        <input type="text" name="name" class="form-control" placeholder="Name"><br>

                        <input type="number" name="dayOfMonth" class="form-control" placeholder="Day (1-31)"><br>

                        <input type="time" name="time" class="form-control"><br>

                        <input type="text" name="address" class="form-control" placeholder="Address"><br>

                        <textarea name="notes" class="form-control" placeholder="Notes"></textarea>

                    </div>

                    <div class="modal-footer">
                        <button type="submit" class="btn btn-primary">Add</button>
                        <button type="button" class="btn btn-default" data-dismiss="modal">Cancel</button>
                    </div>

                </form>

            </div>
        </div>
    </div>

    <!-- Task Detail Modal -->
    <div class="modal fade" id="taskDetailModal">
        <div class="modal-dialog">
            <div class="modal-content">

                <div class="modal-header">
                    <button type="button" class="close" data-dismiss="modal">&times;</button>
                    <h4>Task Details</h4>
                </div>

                <div class="modal-body">

                    <p><strong>Name:</strong> <span id="detailName"></span></p>
                    <p><strong>Schedule:</strong> <span id="detailSchedule"></span></p>
                    <p><strong>Address:</strong> <span id="detailAddress"></span></p>
                    <p><strong>Notes:</strong> <span id="detailNotes"></span></p>

                    <div style="display:flex; gap:10px; margin-top:15px;">
                        <button class="btn btn-warning">Edit</button>
                        <button class="btn btn-danger">Delete</button>
                    </div>

                </div>

            </div>
        </div>
    </div>

    
    <script>
    function toggleComplete(checkbox) {
        const row = checkbox.closest('.task-item');
        const name = row.querySelector('.task-name');

        name.classList.toggle('completed');
    }
    </script>


</section>

</body>
</html>
