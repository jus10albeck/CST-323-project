        .top-bar {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 10px;
            font-size: 25px;

        }

        .company-name {
            color: gold;
            font-weight: bold;
            text-align: center;
            cursor: pointer;

            text-decoration: none;
        }

        .company-name:hover {
            color: gold;
            text-decoration: none;
        }

        .company-name:focus,
        .company-name:active {
            color: gold;
            text-decoration: none;
            outline: none;
        }

        .side-menu {
            position: fixed;
            top: 0;
            left: -45%;
            width: 45%;
            height: 100%;
            background-color: #808080;
            overflow-x: hidden;
            transition: 0.3s;
            padding: 15px;
            z-index: 2000;
            text-align: left;
        }

        .side-menu.open {
            left: 0;
        }

        .menu-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            color: gold;
            margin-bottom: 20px;
        }

        .close-btn {
            cursor: pointer;
            font-size: 22px;
            transition: transform 0.2s ease;
        }

        .close-btn:hover {
            transform: scale(1.1);
        }

        .menu-content {
            padding-left: 0;
            margin-left: 0;
            display: block;
        }

        .menu-content a {
            display: block;
            width: 100%;
            color: gold;
            font-size: 18px;
            margin: 8px 0;
            text-decoration: none;
            transition: transform 0.2s ease;
            padding-left: 10px;
        }

        .menu-content a:hover {
            transform: scale(1.05);
        }

        .menu-footer {
            position: absolute;
            bottom: 20px;
            transition: transform 0.2s ease;
            
        }
        
        .menu-footer a {
            color: gold;
            font-size: 18px;
            text-decoration: none;
            
        }
        
        .menu-footer:hover {
            transform: scale(1.1);
        }
        
        body.menu-open::before {
            content: "";
            position: fixed;
            top:0; left:0;
            width:100%; height:100%;
            background: rgba(0,0,0,0.4);
            z-index: 1500;
        }

        .glyphicon {
            transition: transform 0.2s ease;
        }

        .glyphicon:hover {
            transform: scale(1.1);
        }

